{
  "title": "System Health",
  "uid": "system_health",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uptime",
      "targets": [
        {
          "expr": "time() - process_start_time_seconds",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Memory Usage",
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "Memory MB",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "CPU Usage",
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "System Resources Over Time",
      "targets": [
        {
          "expr": "process_resident_memory_bytes / 1024 / 1024",
          "legendFormat": "Memory",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "CPU",
          "refId": "B"
        }
      ],
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Active Alerts",
      "targets": [
        {
          "expr": "ALERTS",
          "legendFormat": "__auto",
          "refId": "A"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
